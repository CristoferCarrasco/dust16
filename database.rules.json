{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",

        "meta": {
          ".validate": "newData.hasChildren(['createdAt','host'])"
        },

        "players": {
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || !data.exists())",
            ".validate": "newData.hasChildren(['name','x','y','z','yaw','pitch','hp','dead','t'])",
            "name":   { ".validate": "newData.isString() && newData.val().length <= 20" },
            "x":      { ".validate": "newData.isNumber()" },
            "y":      { ".validate": "newData.isNumber()" },
            "z":      { ".validate": "newData.isNumber()" },
            "yaw":    { ".validate": "newData.isNumber()" },
            "pitch":  { ".validate": "newData.isNumber()" },
            "hp":     { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 200" },
            "dead":   { ".validate": "newData.isBoolean()" },
            "weapon": { ".validate": "newData.isString()" },
            "t":      { ".validate": "newData.isNumber()" }
          }
        },

        "events": {
          "$eventId": {
            ".validate": "newData.hasChild('type') && newData.hasChild('from') && newData.child('from').val() === auth.uid",
            "type":       { ".validate": "newData.isString()" },
            "from":       { ".validate": "newData.isString()" },
            "fromName":   { ".validate": "newData.isString()" },
            "to":         { ".validate": "newData.isString()" },
            "dmg":        { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 500" },
            "zone":       { ".validate": "newData.isString()" },
            "victimName": { ".validate": "newData.isString()" },
            "t":          { ".validate": "newData.isNumber()" }
          }
        },

        "projectiles": {
          "$projId": {
            ".validate": "newData.hasChild('type') && newData.hasChild('from') && newData.child('from').val() === auth.uid",
            "type":     { ".validate": "newData.isString()" },
            "from":     { ".validate": "newData.isString()" },
            "fromName": { ".validate": "newData.isString()" },
            "x":        { ".validate": "newData.isNumber()" },
            "y":        { ".validate": "newData.isNumber()" },
            "z":        { ".validate": "newData.isNumber()" },
            "vx":       { ".validate": "newData.isNumber()" },
            "vy":       { ".validate": "newData.isNumber()" },
            "vz":       { ".validate": "newData.isNumber()" },
            "t":        { ".validate": "newData.isNumber()" }
          }
        }
      }
    }
  }
}